# Auto detect text files and perform LF normalization
* text=auto

# Force Unix line endings for these file types
*.sh        text eol=lf
*.rs        text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.htm       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.lock      text eol=lf

# Windows specific files (keep CRLF)
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.xz        binary
